{
  "name": "automotoradar",
  "version": "1.0.0",
  "description": "Comparatore prezzi auto e moto usate",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maxigio/AGG.git"
  },
  "scripts": {
    "start": "node backend/server.js",
    "electron": "electron .",
    "prepare:mac": "node scripts/prepare-mac-chromium.js",
    "build:mac": "npm run prepare:mac && electron-builder --mac --x64",
    "dist:mac": "electron-builder --mac --x64",
    "dist:win": "electron-builder --win --x64",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.automotoradar.app",
    "productName": "Auto Moto Radar",
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright/**",
      "node_modules/playwright-core/**"
    ],
    "extraResources": [
      {
        "from": "pw-browsers",
        "to": "pw-browsers",
        "filter": ["**/*"]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Maxigio",
        "repo": "AGG"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "electron/icon.icns",
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["x64"]
        }
      ]
    },
    "dmg": {
      "writeUpdateInfo": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico"
    },
    "files": [
      "electron/**",
      "backend/**",
      "frontend/**",
      "node_modules/**",
      "!node_modules/electron",
      "!node_modules/electron-builder",
      "data/**",
      "!pw-browsers/**"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.3.0"
  }
}
